# GITB LMS Backend Environment Variables
# Copy this file to .env and fill in your values

# ============ REQUIRED ============
# MongoDB connection string
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# JWT secret for authentication (use a strong random string)
JWT_SECRET=your-secure-jwt-secret-key-here

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLIC_KEY=pk_live_xxxx

# ============ OPTIONAL ============
# Database name
DB_NAME=gitb_lms

# Resend API key for emails (get from https://resend.com)
RESEND_API_KEY=re_xxxx

# Admin email for sending emails
ADMIN_EMAIL=noreply@yourdomain.com

# Frontend URL for email links
FRONTEND_URL=https://yourdomain.com

# CORS origins (comma-separated or * for all)
CORS_ORIGINS=*

# Application fee in EUR
APPLICATION_FEE_EUR=50.00

# Default currency
DEFAULT_CURRENCY=EUR

# Node environment
NODE_ENV=production
